generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MESERO
  CONTADOR
  PENDING
  REJECTED
}

model User {
  id         String   @id @default(uuid())
  telegramId BigInt   @unique
  username   String?
  firstName  String
  role       Role     @default(PENDING)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
