generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MESERO
  CONTADOR
  CLIENTE
  PENDING
  REJECTED
}

model User {
  id           String   @id @default(uuid())
  telegramId   BigInt   @unique
  username     String?
  firstName    String
  phone        String?
  role         Role     @default(PENDING)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]  @relation("OrderWaiter")
  closedOrders Order[]  @relation("OrderCloser")
  clientOrders Order[]     @relation("OrderClient")
  items        OrderItem[]
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  BLOCKED
}

model Table {
  id        String      @id @default(uuid())
  number    Int         @unique
  status    TableStatus @default(AVAILABLE)
  orders    Order[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum OrderStatus {
  CART
  PENDING_APPROVAL
  OPEN
  CLOSED
}

enum PaymentMethod {
  CASH
  CARD
  UNKNOWN
}

model Order {
  id            String        @id @default(uuid())
  tableId       String?
  table         Table?        @relation(fields: [tableId], references: [id])
  userId        String?
  user          User?         @relation("OrderWaiter", fields: [userId], references: [id])
  clientId      String?
  client        User?         @relation("OrderClient", fields: [clientId], references: [id])
  pickupCode    String?
  status        OrderStatus   @default(OPEN)
  total         Float         @default(0.0)
  paymentMethod PaymentMethod @default(UNKNOWN)
  closedById    String?
  closedBy      User?         @relation("OrderCloser", fields: [closedById], references: [id])
  closedAt      DateTime?
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  price     Float
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RestaurantConfig {
  id              Int      @id @default(1)
  logoUrl         String?
  locationText    String?
  thankYouMessage String?
  updatedAt       DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
